#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLT_LIBEXEC="${PLT_LIBEXEC:-$SCRIPT_DIR/..}"
PLT_DATA="${PLT_DATA:-$PLT_LIBEXEC}"

export PLT_LIBEXEC PLT_DATA

ensure_system() {
  /usr/local/bin/container system start 2>/dev/null || true
}

usage() {
  cat <<EOF
Usage: plt <command>

Commands:
  start            Start LanguageTool (detached)
  run              Start LanguageTool (foreground, for brew services)
  stop             Stop LanguageTool
  uninstall        Stop and remove the container and network
  download-ngrams  Download English ngram data (~1.6 GB)
  status           Show container status

LanguageTool runs at http://localhost:8010
EOF
}

cmd_start() {
  ensure_system
  "$PLT_LIBEXEC/container-run.sh"
}

cmd_run() {
  # Foreground mode for brew services: start detached, then tail logs.
  # Trap ensures the container stops when brew services kills this process.
  trap '/usr/local/bin/container stop languagetool 2>/dev/null || true' EXIT INT TERM
  cmd_start
  /usr/local/bin/container logs -f languagetool
}

cmd_stop() {
  /usr/local/bin/container stop languagetool 2>/dev/null || true
}

cmd_uninstall() {
  cmd_stop
  /usr/local/bin/container rm languagetool 2>/dev/null || true
  /usr/local/bin/container network rm languagetool-net 2>/dev/null || true
}

cmd_download_ngrams() {
  "$PLT_LIBEXEC/scripts/download-ngrams.sh"
}

cmd_status() {
  /usr/local/bin/container list --all 2>/dev/null | grep -E '(NAME|languagetool)' || echo "LanguageTool container not found"
}

case "${1:-}" in
  start)           cmd_start ;;
  run)             cmd_run ;;
  stop)            cmd_stop ;;
  uninstall)       cmd_uninstall ;;
  download-ngrams) cmd_download_ngrams ;;
  status)          cmd_status ;;
  -h|--help|"")    usage ;;
  *)               echo "Unknown command: $1" >&2; usage >&2; exit 1 ;;
esac
